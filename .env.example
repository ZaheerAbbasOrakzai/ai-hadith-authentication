# AI Hadith Authenticator - Environment Variables Example
# Copy this file to .env and fill in your actual values

# Hugging Face Configuration
HF_TOKEN=hf_your_huggingface_token_here
HF_SPACE_ID=abbasorakzai777/ai-hadith-authentication
HF_SPACE_URL=https://abbasorakzai777-ai-hadith-authentication.hf.space
HF_MODEL_SUBDIR=final_model
HF_MODEL_CACHE_DIR=.hf-cache

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/hadith_auth

# Email Configuration (for Gmail)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_SSL=True

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Flask Configuration
SECRET_KEY=your_very_secure_secret_key_here_at_least_32_characters
FLASK_ENV=development
FLASK_DEBUG=True

# Sunnah.com API Configuration
SUNNAH_API_KEY=your_sunnah_api_key_here

# Application Settings
APP_NAME=AI Hadith Authenticator
APP_VERSION=1.0.0
APP_URL=http://localhost:5000

# Security Settings
BCRYPT_LOG_ROUNDS=12
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5

# File Upload Settings
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=txt,jpg,jpeg,png,wav,mp3

# Model Settings
MODEL_CONFIDENCE_THRESHOLD=0.5
MODEL_MAX_LENGTH=512
MODEL_BATCH_SIZE=1

# Cache Settings
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760

# Performance Settings
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Development Settings
TESTING=False
DEVELOPMENT=True
PRODUCTION=False

# External API URLs
SUNNAH_BASE_URL=https://api.sunnah.com
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# SSL Configuration (for production)
SSL_DISABLE=False
SSL_CERT_PATH=
SSL_KEY_PATH=

# Database Backup Settings
BACKUP_ENABLED=True
BACKUP_INTERVAL=24
BACKUP_FOLDER=backups

# Monitoring Settings
SENTRY_DSN=
ENABLE_METRICS=True

# Feature Flags
ENABLE_AI_CHAT=True
ENABLE_QURAN_READER=True
ENABLE_HADITH_SEARCH=True
ENABLE_ANALYSIS=True

# UI Settings
THEME=dark
LANGUAGE=en
TIMEZONE=UTC

# API Rate Limiting
API_RATE_LIMIT=100
API_RATE_PERIOD=60

# Search Settings
SEARCH_RESULTS_LIMIT=20
SEARCH_CACHE_TIMEOUT=300

# Model Fallback Settings
ENABLE_DIRECT_MODEL=True
ENABLE_HF_API=True
ENABLE_FALLBACK=True

# Error Handling
SEND_ERROR_EMAILS=True
ADMIN_EMAIL=admin@example.com
